# Local iOS deploy config. Copy to `.env` (git-ignored) and fill in your values.
# Both are optional: with no device set, the deploy targets the first connected device.

# Your iPhone/iPad UDID or a device-name substring (used by Scripts/build-ios.sh device).
DUNEII_DEVICE=
# Your Apple Developer team ID, for automatic code signing (device builds / archive).
DUNEII_TEAM=
