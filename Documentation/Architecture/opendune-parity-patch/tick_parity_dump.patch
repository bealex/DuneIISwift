diff --git a/src/parity.c b/src/parity.c
new file mode 100644
index 0000000..8bda51f
--- /dev/null
+++ b/src/parity.c
@@ -0,0 +1,275 @@
+/** @file src/parity.c Tick-parity golden-dump harness (patch).
+ *
+ * See Documentation/Architecture/TickParityHarness.md for the design.
+ *
+ * In parity mode we:
+ *   1. skip audio / input / real-time timer callbacks,
+ *   2. load a save via SaveGame_LoadFile (no menu, no input injection),
+ *   3. dump tick 0 state,
+ *   4. run g_parityTicks tight-loop ticks with manually-advanced g_timerGame
+ *      / g_timerGUI, dumping after each,
+ *   5. exit(0).
+ *
+ * RNG state is NOT in the dump in v1: tools.c is in the design-doc
+ * "must not modify" list, and both engines seed their RNGs from the save
+ * bytes by construction, so tick 0 shares the same RNG state already.
+ *
+ * Widen the schema only when a divergence demands it.
+ */
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+
+#include "os/common.h"
+#include "os/math.h"
+#include "os/strings.h"
+
+#include "types.h"
+#include "parity.h"
+
+#include "audio/driver.h"
+#include "config.h"
+#include "house.h"
+#include "load.h"
+#include "pool/house.h"
+#include "pool/structure.h"
+#include "pool/unit.h"
+#include "structure.h"
+#include "timer.h"
+#include "tools.h"
+#include "unit.h"
+
+extern void GameLoop_Team(void);
+extern void GameLoop_Unit(void);
+extern void GameLoop_Structure(void);
+extern void GameLoop_House(void);
+
+bool        g_parityMode = false;
+const char *g_parityLoadPath = NULL;
+const char *g_parityDumpPath = NULL;
+const char *g_parityDataDir  = NULL;
+uint32      g_parityTicks = 0;
+
+static bool startsWith(const char *s, const char *prefix)
+{
+	size_t n = strlen(prefix);
+	return strncmp(s, prefix, n) == 0;
+}
+
+bool Parity_ParseArgs(int argc, char **argv)
+{
+	int i;
+	for (i = 1; i < argc; i++) {
+		const char *a = argv[i];
+		if (startsWith(a, "--parity-load=")) {
+			g_parityLoadPath = a + strlen("--parity-load=");
+			g_parityMode = true;
+		} else if (startsWith(a, "--parity-dump=")) {
+			g_parityDumpPath = a + strlen("--parity-dump=");
+			g_parityMode = true;
+		} else if (startsWith(a, "--parity-ticks=")) {
+			g_parityTicks = (uint32)strtoul(a + strlen("--parity-ticks="), NULL, 10);
+			g_parityMode = true;
+		} else if (startsWith(a, "--parity-data-dir=")) {
+			g_parityDataDir = a + strlen("--parity-data-dir=");
+			g_parityMode = true;
+		}
+	}
+
+	if (!g_parityMode) return true;
+
+	if (g_parityLoadPath == NULL) {
+		fprintf(stderr, "parity: --parity-load=<save> is required\n");
+		return false;
+	}
+	if (g_parityDumpPath == NULL) {
+		fprintf(stderr, "parity: --parity-dump=<path> is required\n");
+		return false;
+	}
+	if (g_parityTicks == 0) {
+		fprintf(stderr, "parity: --parity-ticks=<N> must be > 0\n");
+		return false;
+	}
+	if (g_parityDataDir == NULL) {
+		fprintf(stderr, "parity: --parity-data-dir=<path> is required (install root with DUNE.PAK + save files)\n");
+		return false;
+	}
+	return true;
+}
+
+static void Parity_DumpHouses(FILE *f)
+{
+	int i;
+	bool first = true;
+	fprintf(f, "\"houses\":[");
+	for (i = 0; i <= HOUSE_INDEX_MAX; i++) {
+		House *h = House_Get_ByIndex((uint8)i);
+		if (h == NULL) continue;
+		if (!h->flags.used) continue;
+		if (!first) fputc(',', f);
+		first = false;
+		fprintf(f,
+			"{\"index\":%d,\"credits\":%u,\"creditsStorage\":%u,\"creditsQuota\":%u,"
+			"\"powerProduction\":%u,\"powerUsage\":%u,"
+			"\"unitCount\":%u,\"unitCountMax\":%u,"
+			"\"harvestersIncoming\":%u,\"starportTimeLeft\":%u,\"starportLinkedID\":%u}",
+			(int)h->index,
+			(unsigned)h->credits, (unsigned)h->creditsStorage, (unsigned)h->creditsQuota,
+			(unsigned)h->powerProduction, (unsigned)h->powerUsage,
+			(unsigned)h->unitCount, (unsigned)h->unitCountMax,
+			(unsigned)h->harvestersIncoming,
+			(unsigned)h->starportTimeLeft, (unsigned)h->starportLinkedID);
+	}
+	fputc(']', f);
+}
+
+static void Parity_DumpStructures(FILE *f)
+{
+	int i;
+	bool first = true;
+	fprintf(f, ",\"structures\":[");
+	for (i = 0; i < STRUCTURE_INDEX_MAX_HARD; i++) {
+		Structure *s = Structure_Get_ByIndex((uint16)i);
+		if (s == NULL) continue;
+		if (!s->o.flags.s.used) continue;
+		if (!first) fputc(',', f);
+		first = false;
+		fprintf(f,
+			"{\"index\":%u,\"type\":%u,\"houseID\":%u,"
+			"\"positionX\":%u,\"positionY\":%u,"
+			"\"hitpoints\":%u,\"hitpointsMax\":%u,"
+			"\"state\":%d,\"countDown\":%u,"
+			"\"linkedID\":%u,\"objectType\":%u,"
+			"\"upgradeLevel\":%u,\"upgradeTimeLeft\":%u}",
+			(unsigned)s->o.index, (unsigned)s->o.type, (unsigned)s->o.houseID,
+			(unsigned)s->o.position.x, (unsigned)s->o.position.y,
+			(unsigned)s->o.hitpoints, (unsigned)s->hitpointsMax,
+			(int)s->state, (unsigned)s->countDown,
+			(unsigned)s->o.linkedID, (unsigned)s->objectType,
+			(unsigned)s->upgradeLevel, (unsigned)s->upgradeTimeLeft);
+	}
+	fputc(']', f);
+}
+
+static void Parity_DumpUnits(FILE *f)
+{
+	int i;
+	bool first = true;
+	fprintf(f, ",\"units\":[");
+	for (i = 0; i < UNIT_INDEX_MAX; i++) {
+		Unit *u = Unit_Get_ByIndex((uint16)i);
+		if (u == NULL) continue;
+		if (!u->o.flags.s.used) continue;
+		if (!first) fputc(',', f);
+		first = false;
+		fprintf(f,
+			"{\"index\":%u,\"type\":%u,\"houseID\":%u,"
+			"\"positionX\":%u,\"positionY\":%u,"
+			"\"hitpoints\":%u,"
+			"\"actionID\":%u,\"nextActionID\":%u,"
+			"\"orientation0Current\":%d,\"orientation0Target\":%d,\"orientation0Speed\":%d,"
+			"\"orientation1Current\":%d,\"orientation1Target\":%d,\"orientation1Speed\":%d,"
+			"\"movingSpeed\":%u,\"speed\":%u,\"speedPerTick\":%u,\"speedRemainder\":%u,"
+			"\"amount\":%u,\"linkedID\":%u,\"inTransport\":%d,"
+			"\"targetMove\":%u,\"targetAttack\":%u,"
+			"\"currentDestX\":%u,\"currentDestY\":%u,"
+			"\"route0\":%u,\"route1\":%u,\"route2\":%u,\"route3\":%u,"
+			"\"spriteOffset\":%d,\"fireDelay\":%u,"
+			"\"wobbleIndex\":%u,\"blinkCounter\":%u,\"team\":%u,\"timer\":%u,"
+			"\"scriptDelay\":%u,\"scriptPc\":%u,\"scriptSP\":%u,\"scriptFP\":%u}",
+			(unsigned)u->o.index, (unsigned)u->o.type, (unsigned)u->o.houseID,
+			(unsigned)u->o.position.x, (unsigned)u->o.position.y,
+			(unsigned)u->o.hitpoints,
+			(unsigned)u->actionID, (unsigned)u->nextActionID,
+			(int)u->orientation[0].current, (int)u->orientation[0].target, (int)u->orientation[0].speed,
+			(int)u->orientation[1].current, (int)u->orientation[1].target, (int)u->orientation[1].speed,
+			(unsigned)u->movingSpeed, (unsigned)u->speed,
+			(unsigned)u->speedPerTick, (unsigned)u->speedRemainder,
+			(unsigned)u->amount, (unsigned)u->o.linkedID, (int)(u->o.flags.s.inTransport ? 1 : 0),
+			(unsigned)u->targetMove, (unsigned)u->targetAttack,
+			(unsigned)u->currentDestination.x, (unsigned)u->currentDestination.y,
+			(unsigned)u->route[0], (unsigned)u->route[1], (unsigned)u->route[2], (unsigned)u->route[3],
+			(int)u->spriteOffset, (unsigned)u->fireDelay,
+			(unsigned)u->wobbleIndex, (unsigned)u->blinkCounter,
+			(unsigned)u->team, (unsigned)u->timer,
+			(unsigned)u->o.script.delay,
+			(unsigned)(u->o.script.scriptInfo != NULL && u->o.script.script != NULL
+				? (uint32)(u->o.script.script - u->o.script.scriptInfo->start)
+				: 0),
+			(unsigned)u->o.script.stackPointer,
+			(unsigned)u->o.script.framePointer);
+	}
+	fputc(']', f);
+}
+
+static void Parity_DumpTick(FILE *f, uint32 tick)
+{
+	fprintf(f, "{\"tick\":%u,", (unsigned)tick);
+	Parity_DumpHouses(f);
+	Parity_DumpStructures(f);
+	Parity_DumpUnits(f);
+	fputs("}\n", f);
+}
+
+void Parity_Run(void)
+{
+	FILE *f;
+	uint32 t;
+
+	fprintf(stderr, "parity: load=%s dump=%s ticks=%u\n",
+		g_parityLoadPath, g_parityDumpPath, (unsigned)g_parityTicks);
+
+	/* Disable audio / voice / music + pin driver indices to 0xFFFF.
+	 * We skip Drivers_All_Init in parity mode, which leaves s_driverVoice
+	 * (and siblings) with index=0, so Driver_Voice_Play's early-return
+	 * gate (`voice->index == 0xFFFF`) doesn't fire and DSP_Play runs
+	 * against an uninitialised audio device — segfault. Disabling sounds
+	 * at the config gate is the cheaper short-circuit. */
+	g_gameConfig.music = 0;
+	g_gameConfig.sounds = 0;
+	g_driverVoice->index = 0xFFFF;
+	g_driverMusic->index = 0xFFFF;
+	g_driverSound->index = 0xFFFF;
+
+	/* Re-seed the LCG to a fixed value so the parity run is reproducible.
+	 * OpenDune_Init seeds from time(NULL); SaveGame_LoadFile does not
+	 * restore RNG state, so without this the LCG drifts across runs. */
+	Tools_RandomLCG_Seed(0);
+	Tools_Random_Seed(0);
+
+	if (!SaveGame_LoadFile((char *)g_parityLoadPath)) {
+		fprintf(stderr, "parity: SaveGame_LoadFile failed for %s\n", g_parityLoadPath);
+		exit(1);
+	}
+
+	/* SaveGame_LoadFile -> Game_Prepare may consume RNG during setup.
+	 * Re-seed again so tick 1 sees a deterministic RNG state. */
+	Tools_RandomLCG_Seed(0);
+	Tools_Random_Seed(0);
+
+	f = fopen(g_parityDumpPath, "w");
+	if (f == NULL) {
+		fprintf(stderr, "parity: cannot open dump file %s\n", g_parityDumpPath);
+		exit(1);
+	}
+
+	/* tick 0 = post-load, pre-first-tick */
+	g_timerGame = 0;
+	g_timerGUI  = 0;
+	Parity_DumpTick(f, 0);
+
+	for (t = 1; t <= g_parityTicks; t++) {
+		g_timerGame++;
+		g_timerGUI++;
+		GameLoop_Team();
+		GameLoop_Unit();
+		GameLoop_Structure();
+		GameLoop_House();
+		Parity_DumpTick(f, t);
+	}
+
+	fclose(f);
+	fprintf(stderr, "parity: wrote %u ticks to %s\n", (unsigned)g_parityTicks, g_parityDumpPath);
+	exit(0);
+}
diff --git a/src/parity.h b/src/parity.h
new file mode 100644
index 0000000..4c4bed9
--- /dev/null
+++ b/src/parity.h
@@ -0,0 +1,42 @@
+/** @file src/parity.h Tick-parity golden-dump harness (patch). */
+
+#ifndef PARITY_H
+#define PARITY_H
+
+#include "types.h"
+
+/**
+ * Non-zero when --parity-* CLI flags were supplied.
+ * Gates every piece of fast-forward / headless behaviour in the patch.
+ * Vanilla behaviour is bit-identical when this stays false.
+ */
+extern bool g_parityMode;
+
+/** Path to the save file passed via --parity-load=<path>. */
+extern const char *g_parityLoadPath;
+
+/** Path to the JSONL dump passed via --parity-dump=<path>. */
+extern const char *g_parityDumpPath;
+
+/** Install root passed via --parity-data-dir=<path>. Both global and personal. */
+extern const char *g_parityDataDir;
+
+/** Number of ticks to run in deterministic step mode. */
+extern uint32 g_parityTicks;
+
+/**
+ * Parse --parity-load=, --parity-dump=, --parity-ticks= from argv.
+ * Leaves g_parityMode false (and returns true) if no parity flags are given.
+ * Returns false if a flag is malformed — caller should exit(1).
+ */
+extern bool Parity_ParseArgs(int argc, char **argv);
+
+/**
+ * Load g_parityLoadPath, dump tick 0, run g_parityTicks ticks with
+ * manually-advanced timers, dump each tick, then exit(0).
+ * Must be called after all of OpenDUNE's normal init has run
+ * (palettes, scripts, pool _Init) but before the GameLoop_Main state machine.
+ */
+extern void Parity_Run(void);
+
+#endif /* PARITY_H */
